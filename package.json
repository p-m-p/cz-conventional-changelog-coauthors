{
  "name": "cz-conventional-changelog-coauthors",
  "version": "0.0.0-development",
  "description": "cz-conventional-changelog with co-authors prompt",
  "main": "index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "git",
    "github",
    "commit",
    "commitizen",
    "cz",
    "cz-cli",
    "co-authored-by"
  ],
  "author": "Phil Parsons",
  "license": "MIT",
  "engines": {
    "node": ">= 16"
  },
  "dependencies": {
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.0.0",
    "prettier": "^3.5.3",
    "semantic-release": "^25.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./index.js"
    }
  },
  "prettier": {
    "printWidth": 80,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/p-m-p/cz-conventional-changelog-coauthors.git"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70"
}
